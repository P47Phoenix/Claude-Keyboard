/*
 * Claude Code Pad shield overlay.
 *
 * Target MCU: Seeed XIAO nRF52840 (Zephyr board: xiao_ble/nrf52840).
 *
 * Pin map (final, Phase 1 Cycle 5 + Phase 3 Cycle 2 firmware):
 *
 *   XIAO front castellation (1x14):
 *     D0 / P0.02 / AIN0  -> COL0
 *     D1 / P0.03 / AIN1  -> NTC_ADC (pin-rework, see BODGE-MAP)
 *     D2 / P0.28 / AIN4  -> COL2
 *     D3 / P0.29 / AIN5  -> COL3
 *     D4 / P0.04 / AIN2  -> SDA (TWI0, PN532)
 *     D5 / P0.05 / AIN3  -> SCL (TWI0, PN532)
 *     D6 / P1.11         -> COL4
 *     D7 / P1.12         -> ROW0
 *     D8 / P1.13         -> ROW1
 *     D9 / P1.14         -> ROW2
 *     D10 / P1.15        -> COL1 (moved from D1, see BODGE-MAP)
 *
 *   XIAO back-pad bodges (rear-pad J_XIAO_BP cluster, slots 0..6):
 *     slot 0 -> ENC_A         -> back-pad P0.09
 *     slot 1 -> ENC_B         -> back-pad P0.10
 *     slot 2 -> ENC_SW        -> back-pad P1.00  (needs internal pull-up)
 *     slot 3 -> RGB_DIN_MCU   -> back-pad P0.06
 *     slot 4 -> ROW3          -> back-pad P0.08
 *     slot 5 -> VBAT_ADC      -> back-pad P0.31 / AIN7 (SAADC capable)
 *     slot 6 -> ROW4          -> back-pad P1.02
 *
 *   >>> BUILDERS: see BODGE-MAP.md for the definitive wire guide.
 */

#include <dt-bindings/zmk/matrix_transform.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <freq.h>

/ {
	chosen {
		zmk,kscan = &kscan_composite;
		zmk,matrix_transform = &default_transform;
	};

	/*
	 * 5x5 matrix. Rows are the diode-anode side (inputs, pulled up
	 * internally); columns are the driven side.
	 */
	kscan_matrix: kscan_matrix {
		compatible = "zmk,kscan-gpio-matrix";
		diode-direction = "col2row";
		wakeup-source;
		debounce-press-ms = <5>;
		debounce-release-ms = <5>;
		poll-period-ms = <10>;

		row-gpios
			= <&gpio1 12 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW0 -> D7  / P1.12 */
			, <&gpio1 13 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW1 -> D8  / P1.13 */
			, <&gpio1 14 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW2 -> D9  / P1.14 */
			, <&gpio0  8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW3 -> back-pad slot 4 / P0.08 */
			, <&gpio1  2 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>   /* ROW4 -> back-pad slot 6 / P1.02 */
			;

		col-gpios
			= <&gpio0  2 GPIO_ACTIVE_HIGH>    /* COL0 -> D0  / P0.02 */
			, <&gpio1 15 GPIO_ACTIVE_HIGH>    /* COL1 -> D10 / P1.15 (moved) */
			, <&gpio0 28 GPIO_ACTIVE_HIGH>    /* COL2 -> D2  / P0.28 */
			, <&gpio0 29 GPIO_ACTIVE_HIGH>    /* COL3 -> D3  / P0.29 */
			, <&gpio1 11 GPIO_ACTIVE_HIGH>    /* COL4 -> D6  / P1.11 */
			;
	};

	/*
	 * FW-M9: ENC_SW (encoder push) as a direct single-key kscan,
	 * combined into a composite with the main matrix so the matrix
	 * transform can address it at position 25 (row 5, col 0).
	 * ENC_SW sits on back-pad slot 2 / P1.00.
	 *
	 * BODGE-MAP note: P1.00 is the nRF52840 SWO (trace) pin. If live
	 * debug trace is enabled (not by default in our build) this
	 * conflicts. For most builders this is fine; see BODGE-MAP §SWO.
	 */
	kscan_encoder_click: kscan_encoder_click {
		compatible = "zmk,kscan-gpio-direct";
		wakeup-source;
		input-gpios = <&gpio1 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;   /* P1.00 */
	};

	kscan_composite: kscan_composite {
		compatible = "zmk,kscan-composite";
		rows = <6>;
		columns = <5>;

		matrix {
			kscan = <&kscan_matrix>;
		};

		encoder_click {
			kscan = <&kscan_encoder_click>;
			row-offset = <5>;
		};
	};

	/*
	 * 6 rows x 5 cols matrix with ENC_SW at (5, 0) = position 25.
	 */
	default_transform: keymap_transform {
		compatible = "zmk,matrix-transform";
		columns = <5>;
		rows = <6>;
		map = <
			RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)
			RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)
			RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)
			RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
			RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4)
			RC(5,0)
		>;
	};

	/*
	 * EC11 rotary encoder. A/B on back-pad slots 0/1, switch on slot 2
	 * (switch handled by kscan_encoder_click above).
	 */
	left_encoder: encoder_left {
		compatible = "alps,ec11";
		a-gpios = <&gpio0  9 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   /* ENC_A -> P0.09 */
		b-gpios = <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   /* ENC_B -> P0.10 */
		steps = <80>;
		status = "okay";
	};

	sensors: sensors {
		compatible = "zmk,keymap-sensors";
		sensors = <&left_encoder>;
		triggers-per-rotation = <20>;
	};
};

/*
 * -------- RGB WS2812 (SK6812MINI-E) strip --------------------------------
 */
&pinctrl {
	/*
	 * FW-M1 / SF-M3: bias-pull-down on MOSI in BOTH default and
	 * sleep pinctrl states. When the pin is handed back to the
	 * peripheral after the init-safe GPIO LOW hook, the bias
	 * keeps DIN at a defined 0 through any SPI re-init glitch
	 * that would otherwise re-light the LEDs momentarily.
	 */
	spi3_ccp_default: spi3_ccp_default {
		group1 {
			psels = <NRF_PSEL(SPIM_MOSI, 0, 6)>;
			bias-pull-down;
		};
	};
	spi3_ccp_sleep: spi3_ccp_sleep {
		group1 {
			psels = <NRF_PSEL(SPIM_MOSI, 0, 6)>;
			low-power-enable;
			bias-pull-down;
		};
	};
};

&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi3_ccp_default>;
	pinctrl-1 = <&spi3_ccp_sleep>;
	pinctrl-names = "default", "sleep";

	led_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		reg = <0>;
		spi-max-frequency = <4000000>;
		chain-length = <25>;
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
	};
};

/ {
	chosen {
		zmk,underglow = &led_strip;
	};
};

/*
 * -------- SAADC channels: VBAT_ADC, NTC_ADC ------------------------------
 *
 * VBAT_ADC = VBAT / 2 (2x 1 MOhm divider) on back-pad slot 5 -> P0.31 /
 * AIN7. 100 nF ADC cap at the centre tap. Source impedance ~500 kOhm
 * -- SAADC OVERSAMPLE>=2^3 (8 samples) + BURST mode required per
 * firmware/zmk/README.md §Hard Requirement: Battery Cutoff Voltage.
 *
 * NTC_ADC on D1 / P0.03 / AIN1 after the Phase 3 C1 pin rework. 10 kOhm
 * MF52 NTC divided against 10 kOhm R_NTC to GND, high-side-connected to
 * +3V3.
 *
 * Both channels use the internal 0.6 V reference with gain 1/6 giving
 * full-scale 3.6 V -- adequate for 3.3 V rails.
 *
 * SF #23: zephyr,oversampling = <3> (-> 2^3 = 8 samples) AND
 * nordic,burst-enable <3> on each channel, so the SAADC samples in
 * burst mode and averages 8 raw conversions per user-visible sample.
 */
&adc {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	vbat_adc_ch: channel@7 {
		reg = <7>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 40)>;
		zephyr,input-positive = <NRF_SAADC_AIN7>;   /* P0.31 */
		zephyr,resolution = <12>;
		zephyr,oversampling = <3>;   /* 2^3 = 8 samples */
	};

	ntc_adc_ch: channel@1 {
		reg = <1>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME(ADC_ACQ_TIME_MICROSECONDS, 40)>;
		zephyr,input-positive = <NRF_SAADC_AIN1>;   /* P0.03 / D1 */
		zephyr,resolution = <12>;
		zephyr,oversampling = <3>;
		/*
		 * nRF SAADC oversampling >= 2 implicitly enables burst mode
		 * (hardware repeats the configured acquisition N times into
		 * a single averaged result). SF #23 verified.
		 */
	};
};

/ {
	ccp_safety: ccp_safety {
		compatible = "claude-code-pad,ccp-safety";
		io-channels = <&adc 7>, <&adc 1>;
		io-channel-names = "vbat", "ntc";
		vbat-divider-ohms = <1000000 1000000>;
		ntc-beta-k = <3950>;
		ntc-pullup-ohms = <10000>;
		ntc-nominal-ohms = <10000>;
		ntc-nominal-temp-k = <298>;
		status = "okay";
	};
};

/*
 * I2C0 for the PN532 NFC reader (Phase 5 RFID figurine stack) is
 * intentionally left in the board's default disabled state. Adding
 * pinctrl + re-enabling it here would require defining an i2c0_default
 * / i2c0_sleep pinctrl pair; the Phase 5 deliverable will re-enable it
 * then. We do NOT want to carry a half-configured TWI node that would
 * fail DT validation or silently idle the pins.
 */
