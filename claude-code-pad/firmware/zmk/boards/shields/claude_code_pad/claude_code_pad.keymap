/*
 * Claude Code Pad default keymap -- SKELETON.
 *
 * Populated in commit 3 (Claude Code macros + encoder bindings).
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
	keymap {
		compatible = "zmk,keymap";

		default_layer {
			display-name = "Default";
			bindings = <
				&kp N1 &kp N2 &kp N3 &kp N4 &kp N5
				&kp N6 &kp N7 &kp N8 &kp N9 &kp N0
				&kp Y  &kp N  &kp A  &kp LS(A) &kp ESC
				&kp LEFT &kp UP &kp DOWN &kp RIGHT &kp F13
				&kp T1 &kp T2 &kp T3 &kp T4 &kp RET
			>;
		};
	};
};
